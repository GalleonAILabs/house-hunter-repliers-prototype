REPLIERS_API_KEY=your_repliers_api_key_here
REPLIERS_BASE_URL=https://api.repliers.io
PORT=8787
# Shared-secret deterrent for /api/people and /api/feedback (D3/D11).
# Not real access control, just blocks casual drive-by reads/writes over
# the public tunnel URL. Sent as the X-App-Token request header.
APP_AUTH_TOKEN=change_me_to_a_random_string
# Public Mapbox token (served to the browser via /api/config, restricted by URL
# on the Mapbox account, not by secrecy).
MAPBOX_TOKEN=your_mapbox_public_token_here
# In-app issue reporter (GAL-42). Both are server-side only and never reach the
# browser. LINEAR_API_KEY is a Linear personal API key: when set, the Report
# button appears and reports file into team GAL Triage. ANTHROPIC_API_KEY turns
# on the AI first-pass (title, type label, duplicate hint); create a NEW console
# key for this project (per-project billing). LINEAR_TEAM_KEY defaults to GAL.
LINEAR_API_KEY=
ANTHROPIC_API_KEY=
LINEAR_TEAM_KEY=GAL
